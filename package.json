{
  "name": "mindfulnotifier",
  "main": "./index.js",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:watchall": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "prebuild": "expo prebuild --clean",
    "export": "expo export --platform web --clear",
    "dist": "npm run prebuild && npm run export",
    "lint": "expo lint",
    "android-development": "eas build --platform android --profile development --local",
    "android-preview": "eas build --platform android --profile preview --local",
    "android-production": "eas build --platform android --profile production --local"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg))"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@react-navigation/drawer": "^7.9.8",
    "@react-navigation/native": "^7.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@ronradtke/react-native-markdown-display": "^8.1.0",
    "expo": "^55.0.11",
    "expo-application": "~55.0.12",
    "expo-asset": "~55.0.12",
    "expo-background-task": "~55.0.12",
    "expo-battery": "~55.0.11",
    "expo-clipboard": "~55.0.11",
    "expo-constants": "~55.0.11",
    "expo-device": "~55.0.12",
    "expo-document-picker": "~55.0.11",
    "expo-file-system": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-intent-launcher": "~55.0.10",
    "expo-linking": "~55.0.11",
    "expo-notifications": "~55.0.16",
    "expo-router": "~55.0.10",
    "expo-sharing": "~55.0.16",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.13",
    "expo-task-manager": "~55.0.12",
    "expo-web-browser": "~55.0.12",
    "prettier": "^3.8.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "^2.31.0",
    "react-native-paper": "^5.15.0",
    "react-native-paper-dates": "^0.23.5",
    "react-native-reanimated": "^4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.1",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "sweetalert2": "^11.26.24",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "babel-jest": "^29.7.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.13",
    "react-test-renderer": "19.2.0",
    "typescript": "^6.0.2"
  },
  "private": true
}
